pipeline {
    agent any

    environment {
        ANSIBLE_HOST_KEY_CHECKING = 'False'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'master', url: 'https://github.com/saikiranragireddy/employee-leave-portal.git'
            }
        }

        stage('Terraform Init') {
            steps {
                dir('terraform') {
                    sh 'terraform init'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('terraform') {
                    sh 'terraform plan'
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('terraform') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('Wait for Servers') {
            steps {
                sh 'sleep 60'
            }
        }

        stage('Ansible Configure') {
            steps {
                sh 'ansible-playbook -i ansible/inventory.ini ansible/site.yml'
            }
        }
    }

    post {
        success {
            echo '✅ Infrastructure ready!'
        }
        failure {
            echo '❌ Infrastructure pipeline failed!'
        }
    }
}
