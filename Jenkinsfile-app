pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "kiran21sai/employee-leave-portal:v${BUILD_NUMBER}"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'master', url: 'https://github.com/saikiranragireddy/employee-leave-portal.git'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh "docker login -u $USERNAME -p $PASSWORD"
                    sh "docker push ${DOCKER_IMAGE}"
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh "sed -i 's|image:.*|image: ${DOCKER_IMAGE}|g' deployment.yml"
                sh 'kubectl apply -f deployment.yml'
                sh 'kubectl apply -f service.yml'
                sh 'kubectl apply -f hpa.yml'
            }
        }

        stage('Verify Deployment') {
            steps {
                sh 'kubectl rollout status deployment/leave-portal'
                sh 'kubectl get pods'
                sh 'kubectl get svc'
                sh 'kubectl get hpa'
            }
        }
    }

    post {
        success {
            echo '✅ Application deployed successfully!'
        }
        failure {
            echo '❌ Application pipeline failed!'
        }
    }
}
